{
  "name": "android-messages-desktop",
  "description": "Messages for web, as a desktop app",
  "version": "6.1.0",
  "author": {
    "name": "OrangeDrangon",
    "email": "25403517+OrangeDrangon@users.noreply.github.com"
  },
  "license": "MIT",
  "copyright": "Copyright 2020 Kyle Rosenberg",
  "homepage": "https://github.com/OrangeDrangon/android-messages-desktop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OrangeDrangon/android-messages-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/OrangeDrangon/android-messages-desktop/issues"
  },
  "main": "app/background.js",
  "desktopName": "pw.kmr.amd",
  "scripts": {
    "dev": "pnpm run build:dev && NODE_ENV=development electron --enable-source-maps ./app/background.js",
    "dist": "pnpm run build && pnpm run package",
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "icons": "png2icons resources/icons/1024x1024.png resources/icon -all -i",
    "lint": "prettier --write . && eslint --fix ./src",
    "package": "electron-builder --config electron-builder.config.js"
  },
  "dependencies": {
    "about-window": "1.15.2",
    "electron-updater": "6.8.9",
    "fs-jetpack": "^5.1.0",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.5",
    "@types/webpack": "5.28.5",
    "@types/webpack-node-externals": "3.0.4",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "electron": "41.10.1",
    "electron-builder": "26.15.3",
    "esbuild": "^0.28.1",
    "esbuild-loader": "^4.5.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "png2icons": "2.0.1",
    "prettier": "^3.9.5",
    "typescript": "7.0.2",
    "typescript-eslint": "8.63.0",
    "webpack": "5.106.2",
    "webpack-cli": "7.2.1",
    "webpack-merge": "6.0.1",
    "webpack-node-externals": "3.0.0"
  }
}
